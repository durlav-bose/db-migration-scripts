# Template for .env — copy to ".env" and fill in real values.
#   cp .env.example .env   (Ubuntu)
#   Copy-Item .env.example .env   (Windows)
# Leave *_PASSWORD blank to be prompted securely at runtime.

# ---- MySQL source / backup ----
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_DB=
MYSQL_PASSWORD=
# Optional backup file name (overwritten each run). Blank => <DB>_<timestamp>.sql.gz
MYSQL_BACKUP_NAME=

# ---- MySQL target (for restore / migrate) ----
MYSQL_TARGET_HOST=
MYSQL_TARGET_PORT=3306
MYSQL_TARGET_USER=
MYSQL_TARGET_DB=
MYSQL_TARGET_PASSWORD=

# ---- PostgreSQL source / backup ----
PG_HOST=
PG_PORT=5432
PG_USER=
PG_DB=
PG_PASSWORD=
# Optional backup file name (overwritten each run). Blank => <DB>_<timestamp>.dump
PG_BACKUP_NAME=

# ---- PostgreSQL target (for restore / migrate) ----
PG_TARGET_HOST=
PG_TARGET_PORT=5432
PG_TARGET_USER=
PG_TARGET_DB=
PG_TARGET_PASSWORD=
